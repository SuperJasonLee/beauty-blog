<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css" integrity="sha512-SzlrxWUlpfuzQ+pcUCosxcglQRNAq/DZjVsC0lE40xsADsfeQoEypE+enwcOiGjk/bSuGGKHEyjSoQ1zVisanQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<script>
  const searchInput = document.querySelector("#suggest-search");
  const searchContainer = document.querySelector(".suggesstions-wrap");
  const suggesstionContainer = document.querySelector(".suggesstions");

  function showRecommendedList(recommendedList) {
    if (!recommendedList.length) {
      return searchContainer.classList.remove("show");
    }
    searchContainer.classList.add("show");
    suggesstionContainer.innerHTML = "";
    recommendedList.map(recommendedItem => {
      const li = document.createElement("li");
      li.textContent = recommendedItem.search;
      suggesstionContainer.appendChild(li);
    });
  }

  suggesstionContainer.addEventListener("click", function(event) {
    if (event.target.tagName === "LI") {
      const selectedSearch = event.target.textContent;
      searchInput.value = selectedSearch;

      // ลิงก์ไปยังหน้าใหม่เมื่อคลิกที่ข้อเสนอแนะ
      window.location.href = `/?s=${encodeURIComponent(selectedSearch)}`;
      
    }
  });

  async function filterSuggesstions() {
    const response = await fetch("/search/suggestion_data.json");
    const suggesstionsList = await response.json();
    let searchValue = searchInput.value;
    let recommendedList = [];
    if (searchValue.length) {
      recommendedList = suggesstionsList.filter((listItem) =>
        listItem.search.toLowerCase().includes(searchValue.toLowerCase())
      );
    }
    showRecommendedList(recommendedList);
  }

  searchInput.addEventListener("keyup", filterSuggesstions);
</script>


<script>
  function initSearchFunctionality() {
    const searchInputMobile = document.querySelector("#suggest-search-mobile");
    const searchContainerMobile = document.querySelector(".suggesstions-wrap-mobile");
    const suggesstionContainerMobile = document.querySelector(".suggesstions-mobile");

    if (!searchInputMobile || !searchContainerMobile || !suggesstionContainerMobile) {
      console.error("One or more elements not found in the DOM.");
      return;
    }

    function showRecommendedListMobile(recommendedList) {
      if (!recommendedList.length) {
        searchContainerMobile.classList.remove("show");
        return;
      }
      searchContainerMobile.classList.add("show");
      suggesstionContainerMobile.innerHTML = "";
      recommendedList.forEach(recommendedItem => {
        const li = document.createElement("li");
        li.textContent = recommendedItem.search;
        suggesstionContainerMobile.appendChild(li);
      });
    }

    suggesstionContainerMobile.addEventListener("click", function(event) {
      if (event.target.tagName === "LI") {
        const selectedSearch = event.target.textContent;
        searchInputMobile.value = selectedSearch;

        // Navigate to new page on suggestion click
        window.location.href = `/?s=${encodeURIComponent(selectedSearch)}`;
      }
    });

    async function filterSuggesstionsMobile() {
      try {
        const responseMobile = await fetch("/search/suggestion_data.json");
        if (!responseMobile.ok) {
          throw new Error("Network response was not ok");
        }
        const suggesstionsListMobile = await responseMobile.json();
        const searchValueMobile = searchInputMobile.value;
        let recommendedList = [];
        if (searchValueMobile.length) {
          recommendedList = suggesstionsListMobile.filter((listItem) =>
            listItem.search.toLowerCase().includes(searchValueMobile.toLowerCase())
          );
        }
        showRecommendedListMobile(recommendedList);
      } catch (error) {
        console.error("Fetching suggestions failed: ", error);
      }
    }

    searchInputMobile.addEventListener("keyup", filterSuggesstionsMobile);
  }
</script>

