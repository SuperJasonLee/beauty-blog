# Daily publish configuration
# 复制本文件为 .env 后按需取消注释/修改
# .env 已在 .gitignore 中，不会被 commit

# AUTO_COMMIT: 发布后自动 git commit（默认 true）
# AUTO_COMMIT=true

# AUTO_PUSH: commit 后自动 git push（默认 false，建议保持 false）
#   true  = 提交后自动推送到 remote（CI 会自动部署）
#   false = 提交是 local，需手动 git push
# AUTO_PUSH=false

# NOTIFY_SOUND: macOS 通知声音（"default" / "Basso" / "Frog" / "Funk" / "Glass" / "Hero" / "Morse" / "Ping" / "Pop" / "Purr" / "Sosumi" / "Submarine" / "Tink"）
# NOTIFY_SOUND=default
